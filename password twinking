import tkinter as tk
from tkinter import simpledialog
import subprocess

PASSWORD = "506082"

unlocked = False

def check_password():
    global unlocked

    pwd = simpledialog.askstring("Password", "Enter password:", show="*")

    if pwd == PASSWORD:
        unlocked = True
        status.config(text="UNLOCKED", fg="green")
        log.insert(tk.END, "Access granted")
    else:
        status.config(text="LOCKED", fg="red")
        log.insert(tk.END, "Wrong password")

def launch_roblox():
    if not unlocked:
        log.insert(tk.END, "Blocked: Not unlocked")
        return

    log.insert(tk.END, "Launching Roblox...")
    subprocess.Popen("start roblox:", shell=True)

root = tk.Tk()
root.title("Roblox Secure Launcher")
root.geometry("320x250")

status = tk.Label(root, text="LOCKED", fg="red", font=("Arial", 16))
status.pack(pady=10)

btn_login = tk.Button(root, text="Enter Password", command=check_password)
btn_login.pack(pady=5)

btn_launch = tk.Button(root, text="Launch Roblox", command=launch_roblox)
btn_launch.pack(pady=5)

log = tk.Listbox(root, width=40, height=8)
log.pack(pady=10)

root.mainloop()
